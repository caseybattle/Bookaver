        .error-page {
          --bg: white;
          --text-primary: #171717;
          --text-secondary: #666;

          display: flex;
          min-height: 100vh;
          align-items: center;
          justify-content: center;
          background-color: var(--bg);
          font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
          margin: 0;
          padding: 1.5rem;
          box-sizing: border-box;
        }

        @media (prefers-color-scheme: dark) {
          .error-page {
            --bg: #0a0a0a;
            --text-primary: #ededed;
            --text-secondary: #a0a0a0;
          }
        }

        .error-content {
          display: flex;
          flex-direction: column;
          max-width: 22rem;
          margin-top: -2rem;
        }

        .error-icon {
          width: 2rem;
          height: 2rem;
        }

        .error-icon svg {
          width: 100%;
          height: 100%;
          color: var(--text-primary);
        }

        .error-title {
          font-size: 1.5rem;
          font-weight: 600;
          line-height: 2rem;
          letter-spacing: -0.06em;
          color: var(--text-primary);
          margin: 0;
          margin-top: 1.5rem;
        }

        .error-description {
          font-size: 1rem;
          font-weight: 400;
          line-height: 1.5rem;
          color: var(--text-primary);
          margin: 0;
          max-width: 20rem;
          margin-top: 0.5rem;
        }

        .error-details {
          display: flex;
          flex-direction: column;
          gap: 0.5rem;
          margin-top: 2rem;
        }

        .error-row {
          display: flex;
          align-items: center;
          gap: 1rem;
